{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "command",
  "commandRunner": {
    "command": "npx playwright test tests/contract/ --project=contract --reporter=line"
  },
  "coverageAnalysis": "off",
  "mutate": [
    "helpers/network-conditions.ts",
    "helpers/stream-injector.ts",
    "helpers/qoe-metrics.ts"
  ],
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "thresholds": {
    "high": 70,
    "low": 50,
    "break": 0
  },
  "timeoutMS": 120000,
  "timeoutFactor": 3,
  "concurrency": 1,
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "ignorePatterns": [
    "node_modules",
    "playwright-report",
    "allure-results",
    "tmp"
  ]
}
