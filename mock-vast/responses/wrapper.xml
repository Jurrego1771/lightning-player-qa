      <AdSystem>MockVAST Wrapper</AdSystem>
      <VASTAdTagURI><![CDATA[http://localhost:9999/vast/preroll]]></VASTAdTagURI>
      <Impression id="wrapper-impression"><![CDATA[http://localhost:9999/track/wrapper-impression]]></Impression>
      <Creatives>
        <Creative>
          <Linear>
            <TrackingEvents>
              <Tracking event="start"><![CDATA[http://localhost:9999/track/wrapper-start]]></Tracking>
              <Tracking event="complete"><![CDATA[http://localhost:9999/track/wrapper-complete]]></Tracking>
            </TrackingEvents>
          </Linear>
        </Creative>
      </Creatives>
    </Wrapper>
  </Ad>
</VAST>
