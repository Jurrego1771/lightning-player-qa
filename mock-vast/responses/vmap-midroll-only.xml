<?xml version="1.0" encoding="UTF-8"?>
<!-- VMAP 1.0 - Mid-roll único a los 5s, sin pre-roll -->
<!-- Usado para tests de: mid-roll cue point trigger (el contenido debe llegar a 5s) -->
<vmap:VMAP xmlns:vmap="http://www.iab.net/videosuite/vmap" version="1.0">

  <!-- Mid-roll a los 5 segundos — fixture VOD local es ~8s, hay margen -->
  <vmap:AdBreak timeOffset="00:00:05.000" breakType="linear" breakId="midroll-5s">
    <vmap:AdSource id="midroll-source" allowMultipleAds="false" followRedirects="true">
      <vmap:AdTagURI templateType="vast3">
        <![CDATA[http://localhost:9999/vast/preroll]]>
      </vmap:AdTagURI>
    </vmap:AdSource>
  </vmap:AdBreak>

</vmap:VMAP>
