{
  "name": "lightning-player-qa",
  "version": "0.1.0",
  "description": "Independent QA automation suite for Mediastream Lightning Player",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:contract": "playwright test tests/contract/ --project=contract",
    "test:e2e": "playwright test tests/e2e/",
    "test:integration": "playwright test tests/integration/",
    "test:visual": "playwright test tests/visual/",
    "test:a11y": "playwright test tests/a11y/",
    "test:performance": "playwright test tests/performance/",
    "test:ci": "playwright test tests/contract/ --project=contract && playwright test tests/e2e/ tests/integration/ tests/visual/ tests/a11y/",
    "test:nightly": "playwright test --config playwright.browserstack.config.ts",
    "test:update-snapshots": "playwright test tests/visual/ --update-snapshots",
    "mock-vast:start": "ts-node mock-vast/server.ts",
    "fixtures:generate": "bash scripts/generate-fixtures.sh",
    "fixtures:serve": "npx serve fixtures/streams -p 9001 --cors",
    "report": "playwright show-report",
    "lint": "eslint tests/",
    "lint:fix": "eslint tests/ --fix",
    "perf:compare": "ts-node scripts/compare-perf.ts",
    "perf:update-baseline": "ts-node scripts/update-perf-baseline.ts",
    "test:performance:full": "playwright test tests/performance/ && npm run perf:compare",
    "flaky:analyze": "ts-node scripts/analyze-flakiness.ts",
    "flaky:update-quarantine": "ts-node scripts/analyze-flakiness.ts --update",
    "notify:test-battery": "ts-node scripts/notify-test-battery.ts",
    "report:pdf": "node scripts/pdf-from-html.js",
    "diff:analyze": "ts-node scripts/analyze-diff.ts",
    "triage:generate": "node scripts/generate-triage.js",
    "triage:generate:tv": "node scripts/generate-triage.js --report playwright-report-tv/report.json",
    "test:tizen": "wdio run wdio.tizen.conf.ts",
    "tizen:setup": "npx appium driver install --source=npm appium-tizen-tv-driver",
    "tizen:pair": "npx appium driver run tizentv pair-remote --host $TIZEN_DEVICE_IP",
    "deploy:tizen": "bash scripts/deploy-tizen.sh",
    "deploy:tizen:launch": "bash scripts/deploy-tizen.sh --launch-only",
    "deploy:tizen:forward": "bash scripts/deploy-tizen.sh --forward-only",
    "deploy:tizen:close": "bash scripts/deploy-tizen.sh --close"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@octokit/rest": "^22.0.1",
    "@playwright/test": "^1.50.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.58.1",
    "@wdio/appium-service": "^8.41.0",
    "@wdio/cli": "^8.41.0",
    "@wdio/globals": "^8.41.0",
    "@wdio/local-runner": "^8.41.0",
    "@wdio/mocha-framework": "^8.41.0",
    "@wdio/spec-reporter": "^8.41.0",
    "@wdio/types": "^8.41.0",
    "appium": "^2.5.0",
    "appium-tizen-tv-driver": "^0.18.1",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-playwright": "^2.10.1",
    "express": "^4.21.0",
    "parse-diff": "^0.12.0",
    "serve": "^14.2.0",
    "simple-git": "^3.36.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "webdriverio": "^8.41.0",
    "ws": "^8.20.0"
  }
}
