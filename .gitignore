# tests/visual/__snapshots__/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# HLS fixtures generados por ffmpeg (binarios pesados — regenerar con npm run fixtures:generate)
fixtures/streams/vod/
fixtures/streams/audio/
fixtures/streams/vod-with-error/

# Performance — resultados del run actual (gitignored, solo el baseline se commitea)
# El baseline commiteado vive en performance-baseline/metrics.json
perf-results/

# Flaky detection — raw run data (gitignored; quarantine.json sí se commitea)
flaky-results/runs/*.json

# Pipeline /pipeline — archivos temporales entre agentes
tmp/

# Historial de pipelines (opcional, se guarda si el usuario lo pide)
pipeline-history/

# Temporales
*.log
*.tmp
.claude/settings.local.json
tmp_b64.json

# Playwright MCP session files (snapshots, screenshots de sesión)
.playwright-mcp/

# Screenshots de debug en raíz
[0-9][0-9]-*.png

# Artefactos locales de QA (evidencias, screenshots, payloads sueltos) — fuera de la raíz
.artifacts/
scratchpad/

# Reportes generados
qa-report*.html
playwright-report-tv/
reports/

# Allure
allure-results/
allure-report/

