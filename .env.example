# ─── Player Under Test ──────────────────────────────────────────────────────
# URL base donde está desplegado el player (staging)
PLAYER_BASE_URL=https://staging.mdstrm.com/player

# URL del HTML de harness local (si se usa modo local)
PLAYER_HARNESS_URL=http://localhost:3000/harness.html

# Modo: "staging" | "local" | "browserstack"
TEST_MODE=staging

# ─── Mock VAST Server ────────────────────────────────────────────────────────
MOCK_VAST_PORT=9999
MOCK_VAST_BASE_URL=http://localhost:9999

# ─── Chaos Stream Proxy ──────────────────────────────────────────────────────
CHAOS_PROXY_PORT=8080
CHAOS_PROXY_BASE_URL=http://localhost:8080

# ─── Test Streams ────────────────────────────────────────────────────────────
# Sobreescribir streams por defecto si hay CDN de staging propio
# STREAM_HLS_VOD=https://...
# STREAM_DASH_VOD=https://...
# STREAM_HLS_LIVE=https://...

# ─── BrowserStack (Tier 2 / Nightly) ────────────────────────────────────────
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# ─── DRM License Servers (para tests de DRM) ─────────────────────────────────
WIDEVINE_LICENSE_URL=https://cwip-shaka-proxy.appspot.com/no_auth
FAIRPLAY_CERT_URL=
FAIRPLAY_LICENSE_URL=

# ─── CI ──────────────────────────────────────────────────────────────────────
CI=false
