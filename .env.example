# ─── Ambiente activo ─────────────────────────────────────────────────────────
# Opciones: dev | staging | prod
# Default: dev
#
# dev     → https://player.cdn.mdstrm.com/lightning_player/develop/api.js
# staging → https://player.cdn.mdstrm.com/lightning_player/staging/api.js
# prod    → https://player.cdn.mdstrm.com/lightning_player/api.js
PLAYER_ENV=dev

# ─── Mock VAST Server ────────────────────────────────────────────────────────
MOCK_VAST_PORT=9999
MOCK_VAST_BASE_URL=http://localhost:9999

# ─── Plataforma Mediastream — API Admin ──────────────────────────────────────
# Necesario para generar Access Tokens de contenido con restricción de acceso
# (live streams, VOD con closed access). Sin esto, los tests de live se saltean.
#
# Cómo obtener tu token:
#   1. Ir a https://dev.platform.mediastre.am
#   2. Settings → API & Tokens → crear token con permisos de lectura
#   3. Pegar el valor hexadecimal aquí
#
# El token de API admin NO expira.
# El access token de playback se genera dinámicamente antes de cada test via
#   POST /api/access/issue  (ver helpers/access-token.ts)
PLATFORM_API_TOKEN=

# URL base del API de plataforma (sin slash final)
#   dev:     https://dev.platform.mediastre.am/api  ← default si no se define
#   prod:    https://platform.mediastre.am/api
PLATFORM_API_URL=https://dev.platform.mediastre.am/api

# ─── BrowserStack (Tier 2 / Nightly) ────────────────────────────────────────
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# ─── DRM License Servers (para tests de DRM) ─────────────────────────────────
WIDEVINE_LICENSE_URL=https://cwip-shaka-proxy.appspot.com/no_auth
FAIRPLAY_CERT_URL=
FAIRPLAY_LICENSE_URL=

# ─── Notion — Risk Register Sync ─────────────────────────────────────────────
# Requerido para que el agente notion-sync actualice la tabla de riesgo
# después de cada ejecución del pipeline /review-diff.
#
# Cómo obtener el token:
#   1. Ir a https://www.notion.so/my-integrations
#   2. Crear integration → copiar "Internal Integration Secret"
#   3. En la página de la tabla → ... → Connections → agregar tu integration
#
# Database ID (ya configurado — no cambiar):
NOTION_TOKEN=
NOTION_DATABASE_ID=9e40a96e-861c-4fb3-b745-02ab1e12290a

# ─── CI ──────────────────────────────────────────────────────────────────────
CI=false
