# ─── Ambiente activo ─────────────────────────────────────────────────────────
# Opciones: dev | staging | prod
# Default: dev
#
# dev     → https://player.cdn.mdstrm.com/lightning_player/develop/api.js
# staging → https://player.cdn.mdstrm.com/lightning_player/staging/api.js
# prod    → https://player.cdn.mdstrm.com/lightning_player/api.js
PLAYER_ENV=dev

# ─── Mock VAST Server ────────────────────────────────────────────────────────
MOCK_VAST_PORT=9999
MOCK_VAST_BASE_URL=http://localhost:9999

# ─── Plataforma Mediastream — API Admin ──────────────────────────────────────
# Necesario para generar Access Tokens de contenido con restricción de acceso
# (live streams, VOD con closed access). Sin esto, los tests de live se saltean.
#
# Cómo obtener tu token:
#   1. Ir a https://dev.platform.mediastre.am
#   2. Settings → API & Tokens → crear token con permisos de lectura
#   3. Pegar el valor hexadecimal aquí
#
# El token de API admin NO expira.
# El access token de playback se genera dinámicamente antes de cada test via
#   POST /api/access/issue  (ver helpers/access-token.ts)
PLATFORM_API_TOKEN=

# URL base del API de plataforma (sin slash final)
#   dev:     https://dev.platform.mediastre.am/api  ← default si no se define
#   prod:    https://platform.mediastre.am/api
PLATFORM_API_URL=https://dev.platform.mediastre.am/api

# ─── BrowserStack (Tier 2 / Nightly) ────────────────────────────────────────
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# ─── DRM License Servers (para tests de DRM) ─────────────────────────────────
WIDEVINE_LICENSE_URL=https://cwip-shaka-proxy.appspot.com/no_auth
FAIRPLAY_CERT_URL=
FAIRPLAY_LICENSE_URL=

# ─── Youbora / NPAW Analytics ───────────────────────────────────────────────
# Account code de la cuenta NPAW. Requerido para tests de integración de Youbora.
# Sin este valor los tests en tests/integration/youbora.spec.ts que esperan beacons
# fallarán (el tracker llama init() con accountCode vacío y retorna sin activarse).
# Obtener en: NPAW Suite → Settings → Account → Account Code
YOUBORA_ACCOUNT_CODE=

# ─── Player repo en GitHub (para diff-analyzer via GitHub API) ───────────────
# Formato: owner/repo  — SIN https://, SIN .git
# El agente diff-analyzer usa esto para leer diffs de PRs y ramas via `gh api`
# sin necesidad de tener el repo clonado localmente.
# Requiere: gh CLI autenticado (gh auth login)
PLAYER_GITHUB_REPO=mediastream/lightning-player

# ─── Player repo local (fallback cuando GitHub API no disponible) ────────────
# Ruta absoluta al repo del player clonado en esta máquina.
# Cada desarrollador debe configurar esto según su entorno local.
# Ejemplos:
#   Windows: D:/Dev/Repos/mediastream/lightning-player
#   macOS:   /Users/tu-usuario/Dev/mediastream/lightning-player
#   Linux:   /home/tu-usuario/Dev/mediastream/lightning-player
PLAYER_LOCAL_REPO=
SLACK_TEST_BATTERY_CHANNEL_ID=
SLACK_TEST_BATTERY_BOT_TOKEN=
# ─── Notion — Risk Register Sync ─────────────────────────────────────────────
# Requerido para que el agente notion-sync actualice la tabla de riesgo
# después de cada ejecución del pipeline /review-diff.
#
# Cómo obtener el token:
#   1. Ir a https://www.notion.so/my-integrations
#   2. Crear integration → copiar "Internal Integration Secret"
#   3. En la página de la tabla → ... → Connections → agregar tu integration
#
# Database ID (ya configurado — no cambiar):
NOTION_TOKEN=
NOTION_DATABASE_ID=9e40a96e-861c-4fb3-b745-02ab1e12290a

# ─── Content IDs por ambiente ────────────────────────────────────────────────
# Los defaults en fixtures/streams.ts apuntan al ambiente DEV.
# Sobreescribir aquí (o en CI secrets) para staging/prod.
#
# Si no se define una variable, se usa el ID de DEV como fallback.
# IDs TODO (podcast, vodMultiAudio) deben reemplazarse cuando se tengan.
#
CONTENT_ID_VOD_SHORT=
CONTENT_ID_VOD_LONG=
CONTENT_ID_LIVE=
CONTENT_ID_DVR=
CONTENT_ID_AUDIO=
CONTENT_ID_RADIO=
CONTENT_ID_PODCAST=
CONTENT_ID_VOD_WITH_SUBTITLES=
CONTENT_ID_VOD_MULTI_AUDIO=
CONTENT_ID_VOD_WITH_ADS=

# ─── LG webOS TV — Hardware físico ──────────────────────────────────────────
# Requerido para correr los tests @tv-hardware en el TV real.
#
# Flujo:
#   1. bash scripts/deploy-webos.sh    → instala la app y abre el tunnel CDP
#   2. npx playwright test --config=playwright.tv.config.ts
#
# Cómo obtener WEBOS_KEY_PASSPHRASE:
#   La clave RSA del TV viene encriptada. La passphrase la provee el Key Server
#   del TV en el momento de configurar Developer Mode. Si cambió, reconectar el
#   TV al Developer Mode App para obtener la nueva passphrase.
#
WEBOS_DEVICE_IP=192.168.0.28
WEBOS_SSH_PORT=9922
WEBOS_SSH_USER=prisoner
WEBOS_KEY_SERVER_PORT=9991
WEBOS_KEY_PASSPHRASE=27DB1D          # passphrase para descifrar la clave RSA del TV
WEBOS_DEVICE_NAME=lg1
WEBOS_APP_ID=com.mediastream.lightningqa
WEBOS_CDP_PORT=9998            # puerto CDP en el TV (Web Inspector)
WEBOS_LOCAL_CDP_PORT=9222      # puerto local del tunnel SSH → TV
HOST_IP=                       # IP del PC en la LAN — el TV lo usa para cargar la app via HTTP

# ─── Samsung Tizen TV — Hardware físico ──────────────────────────────────────
# Requerido para correr los tests @tv-tizen en el TV Samsung real.
#
# Flujo:
#   1. Habilitar Developer Mode en el TV:
#      SmartHub → Apps → Settings → presionar 1-2-3-4-5 con el control
#   2. Registrar la IP de esta máquina como "Developer IP" en el TV
#   3. sdb connect <TIZEN_DEVICE_IP>                   → conectar via sdb
#   4. bash scripts/deploy-tizen.sh                    → instalar y lanzar app
#   5. npm run tizen:setup                             → instalar driver Appium
#   6. npm run tizen:pair                              → emparejar control (una vez)
#   7. Guardar token aquí como TIZEN_RC_TOKEN
#   8. npm run test:tizen                              → correr tests
#
# Cómo obtener TIZEN_CERT_PROFILE:
#   Tizen Studio → Certificate Manager → Add → Tizen certificate
#   Poner el nombre del perfil creado aquí (no la ruta, solo el nombre).
#
# Cómo obtener TIZEN_CHROMEDRIVER_PATH:
#   Verificar versión de Chromium del TV: sdb shell cat /etc/issue
#   Descargar chromedriver matching: https://googlechromelabs.github.io/chrome-for-testing/
#   Apuntar la ruta absoluta del binario descargado aquí.
#   Tizen 8.0 (2024): típicamente Chromium M120+
#
TIZEN_DEVICE_IP=                    # IP del TV en la LAN (ej: 192.168.0.50)
TIZEN_DEVICE_NAME=samsung1          # nombre del device en sdb (ver: sdb devices)
TIZEN_APP_ID=com.mediastream.lightningqa
TIZEN_CERT_PROFILE=                 # nombre del perfil en Certificate Manager
TIZEN_CDP_PORT=9222                 # puerto Web Inspector en el TV
TIZEN_LOCAL_CDP_PORT=9223           # puerto local del port forward (distinto al de webOS)
TIZEN_RC_TOKEN=                     # token de emparejamiento (npm run tizen:pair)
TIZEN_CHROMEDRIVER_PATH=            # ruta absoluta al binario chromedriver

# ─── CI ──────────────────────────────────────────────────────────────────────
CI=false
