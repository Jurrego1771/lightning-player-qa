{
  "schema_version": "1.0",
  "module": "metadata",
  "status": "template",
  "last_verified": "2026-06-05",
  "events": [
    {
      "name": "metadataloading",
      "when": "Metadata está siendo cargada (radio: now-playing fetch en progreso)",
      "payload_shape": {},
      "optional": true
    },
